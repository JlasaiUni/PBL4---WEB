{
  "name": "PBL4 Plantilla Web",

  // Usa Docker Compose para levantar app + MySQL juntos
  "dockerComposeFile": ["../docker-compose.yml"],
  "service": "app",
  "workspaceFolder": "/workspace",

  // Imagen base con Java 21 y herramientas de desarrollo
  "image": "mcr.microsoft.com/devcontainers/java:21",

  // Features adicionales: Docker-outside-of-Docker para usar docker/docker compose desde el terminal
  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {}
  },

  // Monta el código fuente en /workspace dentro del contenedor
  "mounts": [
    "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached"
  ],

  // Sobrescribe el comando de inicio para desarrollo (no ejecuta el JAR)
  "overrideCommand": true,

  // Instalar dependencias Maven al crear el contenedor (usa mvn, disponible en la imagen)
  "postCreateCommand": "mvn dependency:resolve -q && echo '✅ Dependencias Maven resueltas'",

  // Extensiones de VS Code / Cursor recomendadas
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "vscjava.vscode-spring-initializr",
        "vmware.vscode-spring-boot",
        "redhat.vscode-xml",
        "rangav.vscode-thunder-client",
        "mtxr.sqltools",
        "mtxr.sqltools-driver-mysql",
        "eamodio.gitlens",
        "pkief.material-icon-theme"
      ],
      "settings": {
        "java.configuration.updateBuildConfiguration": "automatic",
        "java.compile.nullAnalysis.mode": "automatic",
        "spring-boot.ls.java.home": "/usr/local/sdkman/candidates/java/current",
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "redhat.java",
        "files.exclude": {
          "**/.classpath": true,
          "**/.project": true,
          "**/.settings": true,
          "**/.factorypath": true
        }
      }
    }
  },

  // Variables de entorno para desarrollo dentro del devcontainer
  "remoteEnv": {
    "SPRING_PROFILES_ACTIVE": "dev",
    "JWT_SECRET": "dev-secret-key-change-in-production-must-be-at-least-256-bits"
  },

  // Reenvío de puertos
  "forwardPorts": [8080, 3306],
  "portsAttributes": {
    "8080": {
      "label": "Spring Boot App",
      "onAutoForward": "notify"
    },
    "3306": {
      "label": "MySQL",
      "onAutoForward": "silent"
    }
  }
}
