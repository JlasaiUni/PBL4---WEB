# ============================================================
#  .env.example – Variables de entorno para Docker Compose
#  Copia este fichero a ".env" y ajusta los valores.
#  NUNCA subas ".env" al repositorio (está en .gitignore).
# ============================================================

# ── Base de datos MySQL ───────────────────────────────────────
MYSQL_ROOT_PASSWORD=password
MYSQL_USER=appuser
MYSQL_PASSWORD=password

# ── Spring Boot ───────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod

# ── JWT ───────────────────────────────────────────────────────
# OBLIGATORIO: clave secreta de al menos 256 bits (32 caracteres)
# Genera una con: openssl rand -hex 32
JWT_SECRET=cambia_esto_por_una_clave_segura_de_al_menos_256_bits

# Tiempo de expiración del token de acceso (ms). Por defecto: 24h
JWT_EXPIRATION_MS=86400000

# Tiempo de expiración del refresh token (ms). Por defecto: 7 días
JWT_REFRESH_EXPIRATION_MS=604800000

# ── JVM ──────────────────────────────────────────────────────
JAVA_OPTS=-Xms256m -Xmx512m
